<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ToDoList.MainPage"
    BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
    Title="Мои Задачи">

    <!-- 🔥 ОСНОВНОЙ КОНТЕЙНЕР СТРАНИЦЫ -->
    <Grid RowDefinitions="*,Auto" Padding="0" RowSpacing="0">

        <!-- 📋 ОСНОВНОЕ СОДЕРЖИМОЕ В SCROLLVIEW ДЛЯ ЛУЧШЕЙ ПРОИЗВОДИТЕЛЬНОСТИ -->
        <ScrollView Grid.Row="0">
            <Grid Padding="15" RowDefinitions="Auto,Auto,*" RowSpacing="15">

                <!-- 🔍 СТРОКА ПОИСКА С РАМКОЙ И ТЕНЬЮ -->
                <Frame 
                    Grid.Row="0"
                    CornerRadius="15"
                    Padding="0"
                    HasShadow="True"
                    BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Margin="0,0,0,10">
                    <SearchBar 
                        x:Name="searchBar"
                        Placeholder="🔎 Поиск задач..."
                        TextChanged="OnSearchTextChanged"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        TextColor="{AppThemeBinding Light=#000, Dark=#FFF}"
                        PlaceholderColor="{AppThemeBinding Light=#999, Dark=#666}"/>
                </Frame>

                <!-- 🏷️ ГОРИЗОНТАЛЬНАЯ ПОЛОСА ФИЛЬТРОВ -->
                <ScrollView 
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="0,0,0,10">
                    <HorizontalStackLayout Spacing="8" Padding="0,5">
                        <!-- ФИЛЬТР: ВСЕ ЗАДАЧИ -->
                        <Button Text="Все" 
                                CommandParameter="Все" 
                                Clicked="OnFilterClicked" 
                                Style="{StaticResource FilterButtonStyle}"/>
                        <!-- ФИЛЬТР: РАБОЧИЕ ЗАДАЧИ -->
                        <Button Text="💼 Работа" 
                                CommandParameter="Работа" 
                                Clicked="OnFilterClicked" 
                                Style="{StaticResource FilterButtonStyle}"/>
                        <!-- ФИЛЬТР: ЛИЧНЫЕ ЗАДАЧИ -->
                        <Button Text="👤 Личное" 
                                CommandParameter="Личное" 
                                Clicked="OnFilterClicked" 
                                Style="{StaticResource FilterButtonStyle}"/>
                        <!-- ФИЛЬТР: ДНИ РОЖДЕНИЯ -->
                        <Button Text="🎂 Дни рождения" 
                                CommandParameter="Дни рождения" 
                                Clicked="OnFilterClicked" 
                                Style="{StaticResource FilterButtonStyle}"/>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- 📝 СПИСОК ЗАДАЧ С ОПТИМИЗАЦИЕЙ ПРОИЗВОДИТЕЛЬНОСТИ -->
                <CollectionView 
                    Grid.Row="2"
                    x:Name="tasksCollection"
                    VerticalOptions="FillAndExpand"
                    ItemSizingStrategy="MeasureFirstItem">

                    <!-- ШАБЛОН ЭЛЕМЕНТА ЗАДАЧИ С КРАСИВЫМ ДИЗАЙНОМ -->
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- КАРТОЧКА ЗАДАЧИ С ТЕНЬЮ И СКРУГЛЕННЫМИ УГЛАМИ -->
                            <Frame 
                                CornerRadius="15"
                                Padding="12"
                                Margin="0,6"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                HasShadow="True"
                                BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}">

                                <!-- СЕТКА ДЛЯ РАСПОЛОЖЕНИЯ ЭЛЕМЕНТОВ КАРТОЧКИ -->
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="5">

                                    <!-- ✅ ЧЕКБОКС ДЛЯ ОТМЕТКИ ЗАВЕРШЕНИЯ ЗАДАЧИ -->
                                    <CheckBox 
                                        Grid.RowSpan="3"
                                        IsChecked="{Binding IsCompleted}"
                                        VerticalOptions="Start"
                                        Margin="0,2,10,0"/>

                                    <!-- 📌 НАЗВАНИЕ ЗАДАЧИ (ОСНОВНОЙ ТЕКСТ) -->
                                    <Label 
                                        Grid.Column="1"
                                        Text="{Binding Title}"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation"
                                        TextColor="{AppThemeBinding Light=#000, Dark=#FFF}"/>

                                    <!-- 🏷️ КАТЕГОРИЯ ЗАДАЧИ -->
                                    <Label 
                                        Grid.Column="1"
                                        Grid.Row="1"
                                        Text="{Binding Category, StringFormat='📂 {0}'}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>

                                    <!-- 📅 ДАТА И ВРЕМЯ ЗАДАЧИ -->
                                    <Label 
                                        Grid.Column="1"
                                        Grid.Row="2"
                                        Text="{Binding Date, StringFormat='📆 {0:dd.MM.yyyy}'}"
                                        FontSize="11"
                                        TextColor="{AppThemeBinding Light=#999, Dark=#777}"/>

                                    <!-- 🎨 КНОПКИ ДЕЙСТВИЙ (УДАЛЕНИЕ И ИЗБРАННОЕ) -->
                                    <HorizontalStackLayout 
                                        Grid.Column="2"
                                        Grid.RowSpan="3"
                                        Spacing="8"
                                        VerticalOptions="Center">

                                        <!-- 🗑️ КНОПКА УДАЛЕНИЯ ЗАДАЧИ -->
                                        <Button 
                                            Text="🗑"
                                            FontSize="16"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            CornerRadius="8"
                                            Padding="0"
                                            BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3D1F1F}"
                                            TextColor="{AppThemeBinding Light=#C62828, Dark=#EF5350}"
                                            Clicked="OnDeleteTaskClicked"
                                            CommandParameter="{Binding .}"/>

                                        <!-- ⭐ КНОПКА ДОБАВЛЕНИЯ В ИЗБРАННОЕ (С АНИМАЦИЕЙ) -->
                                        <Button 
                                            x:Name="favoriteBtn"
                                            FontSize="18"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            CornerRadius="8"
                                            Padding="0"
                                            Clicked="OnFavoriteClicked"
                                            CommandParameter="{Binding .}">

                                            <!-- ТРИГГЕРЫ ДЛЯ ИЗМЕНЕНИЯ ВНЕШНЕГО ВИДА -->
                                            <Button.Triggers>
                                                <!-- ЗАДАЧА В ИЗБРАННОМ -->
                                                <DataTrigger 
                                                    TargetType="Button"
                                                    Binding="{Binding IsFavorite}"
                                                    Value="True">
                                                    <Setter Property="TextColor" Value="#FFC107"/>
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFF8E1, Dark=#4D3F0F}"/>
                                                    <Setter Property="Text" Value="★"/>
                                                </DataTrigger>

                                                <!-- ЗАДАЧА НЕ В ИЗБРАННОМ -->
                                                <DataTrigger 
                                                    TargetType="Button"
                                                    Binding="{Binding IsFavorite}"
                                                    Value="False">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#999, Dark=#666}"/>
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"/>
                                                    <Setter Property="Text" Value="☆"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </ScrollView>

        <!-- 🎨 ПЛАВАЮЩИЕ КНОПКИ В НИЖНЕЙ ЧАСТИ -->
        <Grid Grid.Row="1" Padding="15,10" ColumnDefinitions="Auto,*,Auto" BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#1A1A1A}">
            <!-- ➕ КНОПКА ДОБАВЛЕНИЯ НОВОЙ ЗАДАЧИ (ЗЕЛЕНАЯ) -->
            <Button 
                Grid.Column="2"
                Text="+"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#40916C"
                TextColor="White"
                FontSize="30"
                FontAttributes="Bold"
                Clicked="OnAddTaskClicked"
                Padding="0"/>
        </Grid>
    </Grid>

</ContentPage>
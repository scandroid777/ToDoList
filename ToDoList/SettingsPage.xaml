<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoList.SettingsPage"
             Title="Настройки"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

    <VerticalStackLayout Padding="20" Spacing="20">

        <!-- ЗАГОЛОВОК -->
        <Label 
            Text="⚙️ Настройки"
            FontSize="20"
            FontAttributes="Bold"
            TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>

        <!-- РАЗДЕЛИТЕЛЬ -->
        <BoxView 
            HeightRequest="1" 
            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"/>

        <!-- ПЕРЕКЛЮЧАТЕЛЬ ТЕМЫ -->
        <Frame 
            CornerRadius="12"
            Padding="15"
            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
            BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label 
                    Text="🌙"
                    FontSize="20"
                    VerticalOptions="Center"/>
                <Label 
                    Text="Тёмная тема"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                <Switch 
                    x:Name="themeSwitch"
                    Toggled="OnThemeChanged"
                    HorizontalOptions="EndAndExpand"/>
            </HorizontalStackLayout>
        </Frame>

        <!-- РАЗДЕЛИТЕЛЬ -->
        <BoxView 
            HeightRequest="1" 
            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"/>

        <!-- О ПРИЛОЖЕНИИ -->
        <Label 
            Text="ℹ️ О приложении"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>

        <Frame 
            CornerRadius="12"
            Padding="15"
            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
            BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}">
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="ToDoList"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                <Label 
                    Text="Версия: 1.0"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>
                <Label 
                    Text="Приложение для управления вашими задачами и планирования дня"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#999, Dark=#777}"
                    LineBreakMode="WordWrap"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoList.FavoritesPage"
             BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
             Title="Избранное">

    <!-- 📋 ОСНОВНОЙ КОНТЕЙНЕР СТРАНИЦЫ -->
    <Grid RowDefinitions="*,Auto" Padding="0" RowSpacing="0">

        <!-- 📝 СПИСОК ИЗБРАННЫХ ЗАДАЧ -->
        <CollectionView 
            Grid.Row="0"
            x:Name="favoritesCollection"
            VerticalOptions="FillAndExpand"
            ItemSizingStrategy="MeasureFirstItem"
            Margin="0,0,0,20">

            <!-- ШАБЛОН ЭЛЕМЕНТА ЗАДАЧИ -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- КАРТОЧКА ЗАДАЧИ -->
                    <Frame 
                        Padding="12" 
                        Margin="12,8" 
                        CornerRadius="15"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        HasShadow="True"
                        BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}">

                        <!-- ДОБАВЛЯЕМ GESTURE RECOGNIZER ДЛЯ РЕДАКТИРОВАНИЯ ПО НАЖАТИЮ -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTaskTapped"/>
                        </Frame.GestureRecognizers>

                        <!-- СЕТКА ЭЛЕМЕНТОВ КАРТОЧКИ -->
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="5">

                            <!-- ✅ ЧЕКБОКС -->
                            <CheckBox 
                                Grid.RowSpan="3"
                                IsChecked="{Binding IsCompleted}"
                                Color="#40916C"
                                VerticalOptions="Start"
                                Margin="0,2,10,0"/>

                            <!-- ЗАГОЛОВОК -->
                            <Label 
                                Grid.Column="1"
                                Text="{Binding Title}"
                                FontAttributes="Bold"
                                FontSize="15"
                                MaxLines="1"
                                LineBreakMode="TailTruncation"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                            <!-- КАТЕГОРИЯ -->
                            <Label 
                                Grid.Column="1"
                                Grid.Row="1"
                                Text="{Binding Category}"
                                FontSize="12"
                                TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>

                            <!-- ДАТА -->
                            <Label 
                                Grid.Column="1"
                                Grid.Row="2"
                                Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}"
                                FontSize="11"
                                TextColor="{AppThemeBinding Light=#999, Dark=#888}"/>

                            <!-- КНОПКИ ДЕЙСТВИЙ -->
                            <HorizontalStackLayout 
                                Grid.Column="2"
                                Grid.RowSpan="3"
                                Spacing="6"
                                VerticalOptions="Center">

                                <!-- УДАЛЕНИЕ -->
                                <Button 
                                    Text="🗑"
                                    FontSize="16"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"
                                    CornerRadius="10"
                                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3E2C2C}"
                                    TextColor="{AppThemeBinding Light=#C62828, Dark=#FF6B6B}"
                                    BorderWidth="0"
                                    Clicked="OnDeleteTaskClicked"
                                    CommandParameter="{Binding .}"/>

                                <!-- ИЗБРАННОЕ -->
                                <Button 
                                    FontSize="18"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"
                                    CornerRadius="10"
                                    Clicked="OnFavoriteClicked"
                                    CommandParameter="{Binding .}">
                                    <Button.Triggers>
                                        <DataTrigger 
                                            TargetType="Button"
                                            Binding="{Binding IsFavorite}"
                                            Value="True">
                                            <Setter Property="Text" Value="★"/>
                                            <Setter Property="TextColor" Value="#FFC107"/>
                                            <Setter Property="BackgroundColor" Value="#FFF8E1"/>
                                        </DataTrigger>
                                        <DataTrigger 
                                            TargetType="Button"
                                            Binding="{Binding IsFavorite}"
                                            Value="False">
                                            <Setter Property="Text" Value="☆"/>
                                            <Setter Property="TextColor" Value="#999"/>
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 🟠 ПУСТО: НЕТ ИЗБРАННЫХ ЗАДАЧ -->
        <VerticalStackLayout 
            Grid.Row="0"
            VerticalOptions="CenterAndExpand" 
            IsVisible="False" 
            x:Name="emptyFavoritesStack" 
            Spacing="15" 
            Padding="20">
            <Image 
                Source="empty_favorites.png" 
                WidthRequest="100" 
                HeightRequest="100" 
                Aspect="AspectFit" 
                HorizontalOptions="Center"/>
            <Label 
                Text="У вас нет избранных задач" 
                FontSize="18" 
                FontAttributes="Bold" 
                TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}" 
                HorizontalOptions="Center" 
                HorizontalTextAlignment="Center"/>
            <Label 
                Text="Нажмите звездочку на задаче чтобы добавить в избранное" 
                FontSize="14" 
                TextColor="{AppThemeBinding Light=#666, Dark=#999}" 
                HorizontalOptions="Center" 
                HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
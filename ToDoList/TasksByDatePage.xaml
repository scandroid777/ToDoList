<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ToDoList.TasksByDatePage"
    BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
    Title="Задачи на дату">

    <!-- 📋 ОСНОВНОЙ КОНТЕЙНЕР -->
    <Grid RowDefinitions="*" RowSpacing="0">

        <!-- 📋 СОДЕРЖИМОЕ В SCROLLVIEW -->
        <ScrollView Grid.Row="0">
            <Grid Padding="15" RowDefinitions="Auto,*" RowSpacing="15">

                <!-- 📅 ЗАГОЛОВОК С ДАТОЙ -->
                <Label 
                    Grid.Row="0"
                    x:Name="dateLabel"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    Margin="0"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>

                <!-- 📝 СПИСОК ЗАДАЧ ДЛЯ ВЫБРАННОЙ ДАТЫ -->
                <CollectionView 
                    Grid.Row="1"
                    x:Name="tasksCollection"
                    ItemSizingStrategy="MeasureFirstItem"
                    ItemsUpdatingScrollMode="KeepScrollOffset"
                    VerticalOptions="FillAndExpand"
                    Margin="0">

                    <!-- ШАБЛОН ЭЛЕМЕНТА ЗАДАЧИ -->
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- КАРТОЧКА ЗАДАЧИ С КРАСИВЫМ ОФОРМЛЕНИЕМ -->
                            <Frame 
                                Padding="12" 
                                Margin="0,6" 
                                CornerRadius="12" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" 
                                HasShadow="True"
                                BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}">

                                <!-- СОДЕРЖИМОЕ КАРТОЧКИ -->
                                <VerticalStackLayout Spacing="5">
                                    <!-- НАЗВАНИЕ ЗАДАЧИ -->
                                    <Label 
                                        Text="{Binding Title}" 
                                        FontAttributes="Bold" 
                                        FontSize="15" 
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                                    <!-- КАТЕГОРИЯ ЗАДАЧИ -->
                                    <Label 
                                        Text="{Binding Category}" 
                                        FontSize="12" 
                                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- 🟠 ПУСТО: НЕТ ЗАДАЧ НА ЭТУ ДАТУ -->
                <VerticalStackLayout 
                    Grid.Row="1"
                    VerticalOptions="CenterAndExpand" 
                    IsVisible="False" 
                    x:Name="emptyDateTasksStack" 
                    Spacing="15" 
                    Padding="20">
                    <Image 
                        Source="empty_calendar.png" 
                        WidthRequest="100" 
                        HeightRequest="100" 
                        Aspect="AspectFit" 
                        HorizontalOptions="Center"/>
                    <Label 
                        Text="Нет задач на эту дату" 
                        FontSize="18" 
                        FontAttributes="Bold" 
                        TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}" 
                        HorizontalOptions="Center" 
                        HorizontalTextAlignment="Center"/>
                    <Label 
                        Text="Выберите другую дату в календаре" 
                        FontSize="14" 
                        TextColor="{AppThemeBinding Light=#666, Dark=#999}" 
                        HorizontalOptions="Center" 
                        HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- 🟠 ОТСТУП ВНИЗУ -->
                <BoxView Grid.Row="1" VerticalOptions="End" HeightRequest="100" BackgroundColor="Transparent"/>
            </Grid>
        </ScrollView>

        <!-- 🎨 ПЛАВАЮЩИЕ КНОПКИ (БУРГЕР МЕНЮ) -->
        <AbsoluteLayout>
            <!-- ☰ КНОПКА БУРГЕР МЕНЮ (СЛЕВА ВНИЗУ) ДЛЯ ОТКРЫТИЯ НАСТРОЕК -->
            <Button 
                Text="☰"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="{AppThemeBinding Light=#D8F3DC, Dark=#0F3D1F}"
                TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                FontSize="22"
                Clicked="OnBurgerClicked"
                Padding="0"
                AbsoluteLayout.LayoutBounds="15,0,50,50"
                AbsoluteLayout.LayoutFlags="PositionProportional"/>
        </AbsoluteLayout>

    </Grid>

</ContentPage>
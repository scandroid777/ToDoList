<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ToDoList.AddTaskPage"
    BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
    Title="Новая Задача">

    <!-- 📝 ОСНОВНОЙ КОНТЕЙНЕР СО СКРОЛЛИНГОМ -->
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- 🎯 ЗАГОЛОВОК СТРАНИЦЫ -->
            <Label 
                Text="Создать новую задачу"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                Margin="0,10,0,10"/>

            <!-- 📌 ПОЛЕ ВВОДА НАЗВАНИЯ ЗАДАЧИ -->
            <Label 
                Text="Описание задачи"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

            <Frame 
                CornerRadius="12"
                Padding="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#D0D0D0, Dark=#404040}">
                <!-- ПОЛЕ ДЛЯ ВВОДА ОПИСАНИЯ ЗАДАЧИ -->
                <Editor 
                    x:Name="titleEditor"
                    Placeholder="Введите описание вашей задачи..."
                    AutoSize="TextChanges"
                    HeightRequest="100"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    PlaceholderColor="{AppThemeBinding Light=#999, Dark=#666}"/>
            </Frame>

            <!-- 🏷️ ВЫБОР КАТЕГОРИИ -->
            <Label 
                Text="Категория"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

            <Frame 
                CornerRadius="12"
                Padding="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#D0D0D0, Dark=#404040}">
                <!-- ВЫПАДАЮЩИЙ СПИСОК КАТЕГОРИЙ -->
                <Picker 
                    x:Name="categoryPicker"
                    Title="Выбери категорию"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Без категории</x:String>
                            <x:String>Работа</x:String>
                            <x:String>Личное</x:String>
                            <x:String>Дни рождения</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Frame>

            <!-- 📅 ВЫБОР ДАТЫ -->
            <Label 
                Text="Дата выполнения"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

            <Frame 
                CornerRadius="12"
                Padding="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#D0D0D0, Dark=#404040}">
                <!-- ВЫБОР ДАТЫ ВЫПОЛНЕНИЯ ЗАДАЧИ -->
                <DatePicker 
                    x:Name="datePicker"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
            </Frame>

            <!-- 🎨 РАЗДЕЛИТЕЛЬ -->
            <BoxView 
                HeightRequest="1" 
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                Margin="0,10"/>

            <!-- 🟢 КНОПКА ДОБАВЛЕНИЯ ЗАДАЧИ -->
            <Button 
                Text="+ Добавить задачу"
                BackgroundColor="#40916C"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="16"
                Padding="15,12"
                CornerRadius="10"
                Clicked="OnAddClicked"/>

            <!-- ❌ КНОПКА ОТМЕНЫ -->
            <Button 
                Text="Отмена"
                BackgroundColor="{AppThemeBinding Light=#CCCCCC, Dark=#555}"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                FontAttributes="Bold"
                FontSize="16"
                Padding="15,12"
                CornerRadius="10"
                Clicked="OnCancelClicked"/>

            <!-- 🟠 ПУСТО ДЛЯ СКРОЛЛА -->
            <BoxView HeightRequest="50" BackgroundColor="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
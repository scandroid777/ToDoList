<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoList.CalendarPage"
             BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}">

    <VerticalStackLayout Padding="20" Spacing="20">

        <!-- МЕСЯЦ И СТРЕЛКИ -->
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" Margin="0,10,0,0">

            <!-- СТРЕЛКА ВЛЕВО -->
            <Button Text="◀"
                    FontSize="18"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                    BorderWidth="0"
                    Padding="8"
                    WidthRequest="40"
                    HeightRequest="40"
                    Clicked="OnPrevMonth"/>

            <!-- МЕСЯЦ -->
            <Label x:Name="monthLabel"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                   VerticalOptions="Center"
                   MinimumWidthRequest="180"
                   HorizontalTextAlignment="Center"/>

            <!-- СТРЕЛКА ВПРАВО -->
            <Button Text="▶"
                    FontSize="18"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                    BorderWidth="0"
                    Padding="8"
                    WidthRequest="40"
                    HeightRequest="40"
                    Clicked="OnNextMonth"/>

        </HorizontalStackLayout>

        <!-- ДНИ НЕДЕЛИ -->
        <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="8" RowSpacing="8">
            <Label Text="Пн" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Вт" Grid.Column="1" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Ср" Grid.Column="2" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Чт" Grid.Column="3" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Пт" Grid.Column="4" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Сб" Grid.Column="5" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            <Label Text="Вс" Grid.Column="6" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
        </Grid>

        <!-- КАЛЕНДАРЬ -->
        <ScrollView Orientation="Vertical">
            <Grid x:Name="calendarGrid"
                  ColumnDefinitions="*,*,*,*,*,*,*"
                  RowSpacing="8"
                  ColumnSpacing="8"
                  Padding="5"/>
        </ScrollView>

    </VerticalStackLayout>

</ContentPage>
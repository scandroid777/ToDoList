<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ToDoList.CalendarPage"
    BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
    Title="Календарь">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- НАВИГАЦИЯ ПО МЕСЯЦАМ -->
            <HorizontalStackLayout 
                HorizontalOptions="Center" 
                Spacing="15" 
                Margin="0,10,0,0">

                <Button 
                    Text="Пред"
                    FontSize="14"
                    BackgroundColor="{AppThemeBinding Light=#D8F3DC, Dark=#0F3D1F}"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                    BorderWidth="0"
                    Padding="10,8"
                    CornerRadius="8"
                    Clicked="OnPrevMonth"/>

                <Label 
                    x:Name="monthLabel"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                    VerticalOptions="Center"
                    MinimumWidthRequest="150"
                    HorizontalTextAlignment="Center"/>

                <Button 
                    Text="Далее"
                    FontSize="14"
                    BackgroundColor="{AppThemeBinding Light=#D8F3DC, Dark=#0F3D1F}"
                    TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
                    BorderWidth="0"
                    Padding="10,8"
                    CornerRadius="8"
                    Clicked="OnNextMonth"/>

            </HorizontalStackLayout>

            <!-- ДНИ НЕДЕЛИ (ЗАГОЛОВКИ) -->
            <Grid 
                ColumnDefinitions="*,*,*,*,*,*,*" 
                ColumnSpacing="6" 
                RowSpacing="6"
                Margin="5,10,5,0">

                <Label Text="Пн" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Вт" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Ср" Grid.Column="2" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Чт" Grid.Column="3" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Пт" Grid.Column="4" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Сб" Grid.Column="5" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
                <Label Text="Вс" Grid.Column="6" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"/>
            </Grid>

            <!-- СЕТКА ДНЕЙ МЕСЯЦА -->
            <Frame
                CornerRadius="12"
                Padding="5"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                HasShadow="True"
                BorderColor="Transparent">
                <Grid 
                    x:Name="calendarGrid"
                    ColumnDefinitions="*,*,*,*,*,*,*"
                    RowSpacing="6"
                    ColumnSpacing="6"
                    Padding="5"/>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
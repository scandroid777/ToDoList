<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoList.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoList"
    BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#121212}"
    TabBarBackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1E1E1E}"
    TabBarForegroundColor="{AppThemeBinding Light=#1B4332, Dark=#A8D5BA}"
    TabBarUnselectedColor="{AppThemeBinding Light=#999, Dark=#666}"
    FlyoutBackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

    <!-- ОСНОВНАЯ ПАНЕЛЬ С ВКЛАДКАМИ -->
    <TabBar>
        <!-- ГЛАВНАЯ СТРАНИЦА С СПИСКОМ ЗАДАЧ -->
        <ShellContent
            Title="Главная"
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <!-- СТРАНИЦА ИЗБРАННЫХ ЗАДАЧ -->
        <ShellContent
            Title="Избранное"
            Icon="star.png"
            ContentTemplate="{DataTemplate local:FavoritesPage}" />

        <!-- КАЛЕНДАРЬ ДЛЯ ПЛАНИРОВАНИЯ -->
        <ShellContent
            Title="Календарь"
            Icon="calendar.png"
            ContentTemplate="{DataTemplate local:CalendarPage}" />
    </TabBar>

    <!-- МЕНЮ НАСТРОЕК В БОКОВОЙ ПАНЕЛИ -->
    <FlyoutItem Title="Настройки" Icon="settings.png">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

</Shell>